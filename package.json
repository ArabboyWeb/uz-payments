{
  "name": "uz-payments",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript-first payment infrastructure SDK for Uzbekistan-focused applications.",
  "license": "MIT",
  "author": "uz-payments contributors",
  "homepage": "https://github.com/ArabboyWeb/uz-payments#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArabboyWeb/uz-payments.git"
  },
  "bugs": {
    "url": "https://github.com/ArabboyWeb/uz-payments/issues"
  },
  "keywords": [
    "uzbekistan",
    "payments",
    "payme",
    "merchant-api",
    "typescript",
    "sdk"
  ],
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "payme:live": "tsx scripts/payme-live-runner.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
