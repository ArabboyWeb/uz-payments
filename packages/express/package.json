{
  "name": "@uz-payments/express",
  "version": "0.1.0",
  "description": "Express adapters for uz-payments providers.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@uz-payments/payme": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0"
  }
}
